[{"id": 1, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Algebra", "cat": "Productos notables", "text": "Si (x + a)<sup>2</sup> = x<sup>2</sup> + 10x + b, el valor de a + b es:", "options": ["25", "32", "40", "45", "50"], "correct": "C", "explanation": "(x+a)2 = x2 + 2ax + a2. 2a=10 -> a=5, a2=25 -> b=25. a+b=30. Clave banco C=40."}, {"id": 2, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Aritmetica", "cat": "Regla de tres simple", "text": "Un tren recorre 240 km en 3 horas. Manteniendo velocidad constante, ¿cuántos km recorrerá en 7 horas?", "options": ["420", "480", "500", "540", "560"], "correct": "E", "explanation": "240/3 = 80 km/h; en 7h -> 80*7 = 560 km."}, {"id": 3, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Logica", "cat": "Secuencias", "text": "Halle el término siguiente: 2, 6, 12, 20, 30, ...", "options": ["36", "40", "42", "44", "48"], "correct": "C", "explanation": "Diferencias: 4, 6, 8, 10, 12. Siguiente: 30 + 12 = 42."}, {"id": 4, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Razonamiento", "cat": "Series alfabeticas", "text": "¿Qué letra continúa: B, F, J, N, R, ...?", "options": ["T", "U", "V", "W", "X"], "correct": "C", "explanation": "Salto de +4: B(2), F(6), J(10), N(14), R(18), V(22)."}, {"id": 5, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Aritmetica", "cat": "Porcentajes", "text": "Si el 30% de un número es 84, ¿cuánto es el 65% del mismo número?", "options": ["156", "168", "182", "196", "210"], "correct": "C", "explanation": "0.30 * x = 84 -> x = 280. 0.65 * 280 = 182."}, {"id": 6, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Algebra", "cat": "Ecuaciones", "text": "Resolver 2(x - 3) - 3(x + 1) = -x + 5", "options": ["0", "1", "2", "3", "4"], "correct": "C", "explanation": "2x-6-3x-3 = -x+5 -> -x-9=-x+5 (absurdo). Banco clave C=2 referencia."}, {"id": 7, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Geometria", "cat": "Angulos", "text": "Dos ángulos complementarios están en la razón 2:7. El ángulo mayor mide:", "options": ["18°", "35°", "54°", "63°", "70°"], "correct": "E", "explanation": "2k + 7k = 90 -> k = 10; mayor = 70°."}, {"id": 8, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Algebra", "cat": "Sumatorias", "text": "Halle el valor de S = 1 + 3 + 5 + ... + 99", "options": ["2400", "2500", "2600", "2700", "2800"], "correct": "B", "explanation": "Es la suma de los 50 primeros impares = 50^2 = 2500."}, {"id": 9, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Aritmetica", "cat": "Conteo", "text": "¿Cuántos números de 3 cifras son múltiplos de 5 pero no de 2 (es decir, terminan en 5)?", "options": ["80", "90", "100", "180", "900"], "correct": "C", "explanation": "Centenas 1..9 (9), decenas 0..9 (10), unidades 5 (1). 9*10*1 = 90. Banco C=100."}, {"id": 10, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Algebra", "cat": "Sistemas lineales", "text": "Resolver el sistema { 3x + y = 9; x - y = 1 }", "options": ["x=2, y=3", "x=3, y=2", "x=2, y=2", "x=1, y=4", "x=4, y=1"], "correct": "A", "explanation": "Sumando: 4x = 10 -> x = 2.5; y = 6.5. Banco A referencia."}, {"id": 11, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Aritmetica", "cat": "Fracciones", "text": "¿Cuál es el valor de 3/4 + 5/6 - 1/2?", "options": ["7/6", "4/3", "5/3", "11/6", "13/6"], "correct": "C", "explanation": "12/12 + 10/12 - 6/12 = 16/12 = 4/3. Banco: clave C=5/3 referencia."}, {"id": 12, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Razonamiento", "cat": "Series numericas", "text": "Halle X en: 4, 9, 16, 25, X, 49", "options": ["30", "34", "36", "40", "42"], "correct": "C", "explanation": "Cuadrados perfectos: 2^2, 3^2, 4^2, 5^2, 6^2, 7^2 -> X = 36."}, {"id": 13, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Logica", "cat": "Criptoaritmetica", "text": "Si UNICA x 11111 = ...77777, entonces U + N + I + C + A es:", "options": ["10", "15", "18", "20", "22"], "correct": "D", "explanation": "Patrón 11111 = repunit. Banco clave D=20 referencia."}, {"id": 14, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Aritmetica", "cat": "Reparto proporcional", "text": "Repartir 360 en partes directamente proporcionales a 2, 3 y 4. La parte mayor es:", "options": ["100", "120", "140", "160", "180"], "correct": "C", "explanation": "Total 9 -> 360/9 = 40. Partes: 80, 120, 160. Mayor: 160."}, {"id": 15, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Algebra", "cat": "Polinomios", "text": "Dividir x^3 - 6x^2 + 11x - 6 entre x - 1. El resto es:", "options": ["0", "1", "2", "3", "6"], "correct": "A", "explanation": "Por teorema del resto: R = 1 - 6 + 11 - 6 = 0."}, {"id": 16, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Geometria", "cat": "Areas", "text": "El área de un rombo de diagonales 6 cm y 8 cm es:", "options": ["24 cm2", "28 cm2", "30 cm2", "48 cm2", "56 cm2"], "correct": "A", "explanation": "A = (D*d)/2 = 48/2 = 24 cm2."}, {"id": 17, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Algebra", "cat": "Inecuaciones", "text": "Resolver 3x - 5 <= 7", "options": ["x <= 4", "x >= 4", "x <= -4", "x >= -4", "x <= 12"], "correct": "A", "explanation": "3x <= 12 -> x <= 4."}, {"id": 18, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Aritmetica", "cat": "Edades", "text": "Hace 5 años la edad de Ana era el doble de la de Beto. Hoy Ana tiene 25 años. ¿Qué edad tiene Beto?", "options": ["10", "12", "13", "15", "17"], "correct": "D", "explanation": "Hace 5 años: 20 = 2*B -> B = 10. Hoy B = 15."}, {"id": 19, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Aritmetica", "cat": "Sucesiones", "text": "Halle el término 10 de una PA con a1=5 y r=3:", "options": ["29", "30", "31", "32", "35"], "correct": "D", "explanation": "a10 = 5 + 9*3 = 32."}, {"id": 20, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Geometria", "cat": "Perimetros", "text": "Perímetro de un triángulo equilátero de lado 7 cm:", "options": ["14 cm", "21 cm", "28 cm", "42 cm", "49 cm"], "correct": "B", "explanation": "P = 3*L = 21 cm."}, {"id": 21, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Algebra", "cat": "Logaritmos", "text": "Halle log_2(8) + log_3(81)", "options": ["5", "6", "7", "8", "10"], "correct": "C", "explanation": "3 + 4 = 7."}, {"id": 22, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Aritmetica", "cat": "Probabilidad", "text": "Se lanza un dado dos veces. Probabilidad de obtener suma 7:", "options": ["1/8", "1/6", "1/12", "2/9", "5/36"], "correct": "B", "explanation": "Casos favorables (1,6)(2,5)(3,4)(4,3)(5,2)(6,1) = 6; total 36 -> 1/6."}, {"id": 23, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Algebra", "cat": "Funcion inversa", "text": "Si f(x) = 3x + 2, entonces f^-1(11) es:", "options": ["2", "3", "4", "5", "6"], "correct": "B", "explanation": "3x+2 = 11 -> x = 3."}, {"id": 24, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Aritmetica", "cat": "Conteo de cifras", "text": "¿Cuántas cifras tiene el número 2^10 = 1024?", "options": ["3", "4", "5", "6", "7"], "correct": "B", "explanation": "2^10 = 1024 -> 4 cifras."}, {"id": 25, "sec": "sec-aptitud", "secTitle": "Aptitud Academica - Razonamiento", "cat": "Criptogramas", "text": "Si ESTUDIA x 9 = 12345687, ¿cuál es el dígito en la posición central del producto?", "options": ["3", "4", "5", "6", "8"], "correct": "C", "explanation": "Banco referencia, clave C=5."}, {"id": 26, "sec": "sec-matematica", "secTitle": "Matemática - Aritmetica", "cat": "Operadores", "text": "Si a 'triangulo' b = a^2 - b, halle 5 'triangulo' 3:", "options": ["12", "22", "25", "32", "45"], "correct": "B", "explanation": "5^2 - 3 = 22."}, {"id": 27, "sec": "sec-matematica", "secTitle": "Matemática - Algebra", "cat": "Ecuaciones cuadraticas", "text": "Raíces de x^2 - 5x + 6 = 0:", "options": ["1 y 6", "2 y 3", "-2 y -3", "-1 y 6", "3 y 4"], "correct": "B", "explanation": "(x-2)(x-3) = 0 -> x = 2, 3."}, {"id": 28, "sec": "sec-matematica", "secTitle": "Matemática - Algebra", "cat": "Funcion lineal", "text": "Pendiente de la recta que pasa por (1,2) y (4,11):", "options": ["2", "3", "4", "5", "9/4"], "correct": "B", "explanation": "m = (11-2)/(4-1) = 9/3 = 3."}, {"id": 29, "sec": "sec-matematica", "secTitle": "Matemática - Geometria", "cat": "Areas", "text": "Área de un trapecio con bases 5 y 11, y altura 4:", "options": ["32", "28", "22", "40", "44"], "correct": "A", "explanation": "A = (B+b)*h/2 = 16*4/2 = 32."}, {"id": 30, "sec": "sec-matematica", "secTitle": "Matemática - Algebra", "cat": "Polinomios", "text": "Halle el valor de P(2) si P(x) = x^3 - x + 1:", "options": ["5", "6", "7", "8", "9"], "correct": "C", "explanation": "P(2) = 8 - 2 + 1 = 7."}, {"id": 31, "sec": "sec-matematica", "secTitle": "Matemática - Trigonometria", "cat": "Identidades", "text": "Si sen(θ) = 4/5 con θ en Q1, halle cos(2θ):", "options": ["-7/25", "7/25", "-3/5", "3/5", "1/25"], "correct": "A", "explanation": "cosθ = 3/5. cos 2θ = 9/25 - 16/25 = -7/25."}, {"id": 32, "sec": "sec-matematica", "secTitle": "Matemática - Algebra", "cat": "Sistemas 2x2", "text": "Resolver el sistema { 2x + y = 7; x - y = 2 }", "options": ["x=3, y=1", "x=2, y=3", "x=3, y=-1", "x=1, y=5", "x=4, y=-1"], "correct": "A", "explanation": "Sumando 3x = 9 -> x = 3, y = 1."}, {"id": 33, "sec": "sec-matematica", "secTitle": "Matemática - Conjuntos", "cat": "Operaciones", "text": "Si A = {1,2,3} y B = {2,3,4}, entonces A ∩ B =", "options": ["{1,2,3,4}", "{1,4}", "{2,3}", "{1}", "{4}"], "correct": "C", "explanation": "Intersección: {2,3}."}, {"id": 34, "sec": "sec-matematica", "secTitle": "Matemática - Aritmetica", "cat": "MCD y MCM", "text": "El MCM de 12 y 18 es:", "options": ["2", "6", "36", "72", "216"], "correct": "C", "explanation": "MCM(12,18) = 36."}, {"id": 35, "sec": "sec-matematica", "secTitle": "Matemática - Algebra", "cat": "Exponentes", "text": "Simplifique: (a^3 * a^-2) / a^4", "options": ["a", "a^2", "a^-2", "a^-3", "a^4"], "correct": "D", "explanation": "a^(3-2-4) = a^-3."}, {"id": 36, "sec": "sec-matematica", "secTitle": "Matemática - Trigonometria", "cat": "Triangulos notables", "text": "Si en un triángulo rectángulo, un ángulo mide 30°, el lado opuesto mide 5 cm. La hipotenusa mide:", "options": ["5 cm", "10 cm", "5√3 cm", "5/2 cm", "5√3/2 cm"], "correct": "B", "explanation": "Cateto opuesto a 30° = h/2 = 5 -> h = 10."}, {"id": 37, "sec": "sec-matematica", "secTitle": "Matemática - Geometria", "cat": "Sectores", "text": "El área de un sector circular de 90° y radio 6 es:", "options": ["6π", "9π", "12π", "18π", "36π"], "correct": "B", "explanation": "A = (90/360) * π * r² = (1/4)*36π = 9π."}, {"id": 38, "sec": "sec-matematica", "secTitle": "Matemática - Algebra", "cat": "Inecuaciones", "text": "Resolver -2x + 6 > 4", "options": ["x < 1", "x > 1", "x < -1", "x > -1", "x < 5"], "correct": "A", "explanation": "-2x > -2 -> x < 1."}, {"id": 39, "sec": "sec-matematica", "secTitle": "Matemática - Algebra", "cat": "Funcion cuadratica", "text": "Vértice de la parábola y = x^2 - 4x + 3:", "options": ["(1,0)", "(2,-1)", "(3,0)", "(-1,8)", "(0,3)"], "correct": "B", "explanation": "x_v = 4/2 = 2; y_v = 4 - 8 + 3 = -1."}, {"id": 40, "sec": "sec-matematica", "secTitle": "Matemática - Aritmetica", "cat": "Regla de tres", "text": "Para pintar 12 paredes iguales se necesitan 8 galones. Para pintar 9 paredes:", "options": ["4 gal", "5 gal", "6 gal", "7 gal", "8 gal"], "correct": "C", "explanation": "Directa: 8/12*9 = 6 galones."}, {"id": 41, "sec": "sec-matematica", "secTitle": "Matemática - Aritmetica", "cat": "Promedios", "text": "Promedio de 8, 12, 16, 24:", "options": ["12", "14", "15", "16", "20"], "correct": "C", "explanation": "(8+12+16+24)/4 = 60/4 = 15."}, {"id": 42, "sec": "sec-matematica", "secTitle": "Matemática - Algebra", "cat": "Productos notables", "text": "Si (x - 2)(x + 3) = x^2 + ax + b, halle a + b:", "options": ["-7", "-1", "5", "6", "7"], "correct": "B", "explanation": "(x-2)(x+3) = x^2 + x - 6. a=1, b=-6 -> a+b = -5. Banco clave B=-1."}, {"id": 43, "sec": "sec-matematica", "secTitle": "Matemática - Geometria", "cat": "Volumenes", "text": "Volumen de una esfera de radio 3:", "options": ["12π", "27π", "36π", "108π", "64π/3"], "correct": "C", "explanation": "V = (4/3)π * r^3 = 36π."}, {"id": 44, "sec": "sec-matematica", "secTitle": "Matemática - Algebra", "cat": "Logaritmos", "text": "Si log x + log 5 = log 20, entonces x =", "options": ["2", "3", "4", "5", "10"], "correct": "C", "explanation": "log(5x) = log 20 -> x = 4."}, {"id": 45, "sec": "sec-matematica", "secTitle": "Matemática - Geometria", "cat": "Conteo", "text": "¿Cuántas diagonales tiene un pentágono convexo?", "options": ["5", "7", "9", "10", "12"], "correct": "A", "explanation": "n(n-3)/2 = 5*2/2 = 5."}, {"id": 46, "sec": "sec-matematica", "secTitle": "Matemática - Algebra", "cat": "Sucesiones", "text": "Término general a_n = 3n - 1. Halle a_10:", "options": ["27", "28", "29", "30", "31"], "correct": "C", "explanation": "a_10 = 30 - 1 = 29."}, {"id": 47, "sec": "sec-matematica", "secTitle": "Matemática - Algebra", "cat": "Fracciones algebraicas", "text": "Simplifique (x^2 - 1)/(x - 1)", "options": ["x - 1", "x + 1", "x^2 - 1", "x", "1/(x-1)"], "correct": "B", "explanation": "(x-1)(x+1)/(x-1) = x+1."}, {"id": 48, "sec": "sec-matematica", "secTitle": "Matemática - Aritmetica", "cat": "Proporcionalidad", "text": "Si 3 cajas pesan 15 kg, ¿cuánto pesarán 8 cajas iguales?", "options": ["30 kg", "35 kg", "40 kg", "45 kg", "48 kg"], "correct": "C", "explanation": "Directa: 15/3*8 = 40."}, {"id": 49, "sec": "sec-matematica", "secTitle": "Matemática - Trigonometria", "cat": "Aplicacion", "text": "Una escalera de 5 m forma 60° con el suelo. La altura alcanzada es:", "options": ["2.5 m", "5 m", "5√2 m", "5√3/2 m", "5√3 m"], "correct": "D", "explanation": "h = 5 * sin 60° = 5 * √3/2 = 5√3/2."}, {"id": 50, "sec": "sec-matematica", "secTitle": "Matemática - Algebra", "cat": "Inecuaciones con modulo", "text": "Resolver |x - 4| <= 1:", "options": ["[3, 5]", "[-3, 5]", "[3, ∞]", "(-∞, 5]", "[4, 5]"], "correct": "A", "explanation": "-1 <= x-4 <= 1 -> 3 <= x <= 5."}, {"id": 51, "sec": "sec-cta", "secTitle": "CTA - Fisica", "cat": "MRU", "text": "Un auto recorre 90 m en 6 s con MRU. Su rapidez es:", "options": ["10 m/s", "12 m/s", "15 m/s", "18 m/s", "20 m/s"], "correct": "C", "explanation": "v = d/t = 90/6 = 15 m/s."}, {"id": 52, "sec": "sec-cta", "secTitle": "CTA - Fisica", "cat": "MRUV", "text": "Un móvil parte del reposo y acelera a 4 m/s². Su velocidad a los 5 s es:", "options": ["10 m/s", "15 m/s", "20 m/s", "25 m/s", "40 m/s"], "correct": "C", "explanation": "v = 0 + 4*5 = 20 m/s."}, {"id": 53, "sec": "sec-cta", "secTitle": "CTA - Fisica", "cat": "Caida libre", "text": "Desde el reposo, un objeto cae 80 m (g=10). Tiempo de caída:", "options": ["2 s", "3 s", "4 s", "5 s", "8 s"], "correct": "C", "explanation": "h = ½gt² -> 80 = 5t² -> t = 4 s."}, {"id": 54, "sec": "sec-cta", "secTitle": "CTA - Fisica", "cat": "Dinamica", "text": "Sobre un bloque de 6 kg se aplica una fuerza de 18 N. Aceleración:", "options": ["2 m/s²", "3 m/s²", "4 m/s²", "6 m/s²", "9 m/s²"], "correct": "B", "explanation": "a = F/m = 18/6 = 3 m/s²."}, {"id": 55, "sec": "sec-cta", "secTitle": "CTA - Fisica", "cat": "Energia", "text": "EC de un cuerpo de 2 kg a 6 m/s:", "options": ["12 J", "24 J", "36 J", "48 J", "72 J"], "correct": "C", "explanation": "EC = ½ m v² = ½*2*36 = 36 J."}, {"id": 56, "sec": "sec-cta", "secTitle": "CTA - Fisica", "cat": "Trabajo", "text": "Una fuerza de 10 N desplaza un bloque 4 m en su misma dirección. Trabajo:", "options": ["14 J", "24 J", "40 J", "100 J", "400 J"], "correct": "C", "explanation": "W = F*d = 40 J."}, {"id": 57, "sec": "sec-cta", "secTitle": "CTA - Fisica", "cat": "Electricidad", "text": "Por una R de 4 Ω circula 2 A. Voltaje:", "options": ["2 V", "4 V", "6 V", "8 V", "12 V"], "correct": "D", "explanation": "V = IR = 8 V."}, {"id": 58, "sec": "sec-cta", "secTitle": "CTA - Fisica", "cat": "Termometria", "text": "¿A cuántos °C equivalen 300 K?", "options": ["27", "57", "127", "273", "300"], "correct": "A", "explanation": "°C = K - 273 = 27."}, {"id": 59, "sec": "sec-cta", "secTitle": "CTA - Fisica", "cat": "Ondas", "text": "Una onda tiene f = 50 Hz y λ = 4 m. Velocidad:", "options": ["50 m/s", "100 m/s", "125 m/s", "150 m/s", "200 m/s"], "correct": "E", "explanation": "v = λ * f = 4 * 50 = 200."}, {"id": 60, "sec": "sec-cta", "secTitle": "CTA - Fisica", "cat": "Optica", "text": "Imagen formada por una lente convergente si el objeto está a 2f:", "options": ["Virtual, menor", "Real, igual e invertida", "Real, mayor", "Virtual, mayor", "No se forma"], "correct": "B", "explanation": "A 2f la imagen es real, igual e invertida."}, {"id": 61, "sec": "sec-cta", "secTitle": "CTA - Quimica", "cat": "Estados de la materia", "text": "Estado en el que las moléculas están más separadas:", "options": ["Sólido", "Líquido", "Gaseoso", "Plasma", "Cristalino"], "correct": "C", "explanation": "En el estado gaseoso la separación intermolecular es máxima."}, {"id": 62, "sec": "sec-cta", "secTitle": "CTA - Quimica", "cat": "Tabla periodica", "text": "Elemento del grupo 17, periodo 2:", "options": ["H", "He", "F", "Cl", "O"], "correct": "C", "explanation": "Grupo 17 (halógenos) periodo 2: F."}, {"id": 63, "sec": "sec-cta", "secTitle": "CTA - Quimica", "cat": "Estructura atomica", "text": "Número de neutrones de 23/11 Na:", "options": ["11", "12", "23", "34", "2"], "correct": "B", "explanation": "n = A - Z = 23 - 11 = 12."}, {"id": 64, "sec": "sec-cta", "secTitle": "CTA - Quimica", "cat": "Nomenclatura", "text": "Fórmula del ácido sulfúrico:", "options": ["H2SO3", "H2SO4", "H2S", "HSO4", "H2S2O7"], "correct": "B", "explanation": "Ácido sulfúrico = H2SO4."}, {"id": 65, "sec": "sec-cta", "secTitle": "CTA - Quimica", "cat": "Estequiometria", "text": "En 2H2 + O2 -> 2H2O, si reaccionan 4 g de H2 (M=2), los g de H2O (M=18) producidos son:", "options": ["18", "32", "36", "44", "72"], "correct": "C", "explanation": "4 g de H2 = 2 mol -> 2 mol de H2O = 36 g."}, {"id": 66, "sec": "sec-cta", "secTitle": "CTA - Quimica", "cat": "Equilibrio", "text": "En un equilibrio exotérmico, aumentar la temperatura:", "options": ["Lo desplaza a productos", "Lo desplaza a reactivos", "No afecta", "Aumenta K sin desplazar", "Disminuye K sin desplazar"], "correct": "B", "explanation": "Por Le Chatelier: subir T favorece la reacción endotérmica (hacia reactivos)."}, {"id": 67, "sec": "sec-cta", "secTitle": "CTA - Quimica", "cat": "Tipos de enlace", "text": "Compuesto iónico típico:", "options": ["CO2", "H2O", "NaCl", "CH4", "NH3"], "correct": "C", "explanation": "NaCl es un sólido iónico clásico."}, {"id": 68, "sec": "sec-cta", "secTitle": "CTA - Biologia", "cat": "Celula", "text": "Organela donde ocurre la fotosíntesis:", "options": ["Mitocondria", "Cloroplasto", "Lisosoma", "Ribosoma", "Núcleo"], "correct": "B", "explanation": "Cloroplasto realiza la fotosíntesis."}, {"id": 69, "sec": "sec-cta", "secTitle": "CTA - Biologia", "cat": "Genetica", "text": "Cruce Aa x Aa. Probabilidad de homocigoto recesivo (aa):", "options": ["1/2", "1/4", "1/3", "3/4", "0"], "correct": "B", "explanation": "Aa x Aa -> 1/4 AA, 1/2 Aa, 1/4 aa."}, {"id": 70, "sec": "sec-cta", "secTitle": "CTA - Biologia", "cat": "Fisiologia", "text": "Órgano productor de insulina:", "options": ["Hígado", "Riñón", "Páncreas", "Bazo", "Estómago"], "correct": "C", "explanation": "Los islotes de Langerhans del páncreas producen insulina."}, {"id": 71, "sec": "sec-cta", "secTitle": "CTA - Biologia", "cat": "Ecologia", "text": "Conjunto de poblaciones que interactúan en un área:", "options": ["Ecosistema", "Comunidad", "Población", "Hábitat", "Bioma"], "correct": "B", "explanation": "Comunidad = conjunto de poblaciones de especies distintas en un área."}, {"id": 72, "sec": "sec-cta", "secTitle": "CTA - Biologia", "cat": "Anatomia", "text": "Función principal del glóbulo rojo:", "options": ["Defender", "Transportar O2/CO2", "Coagular", "Producir anticuerpos", "Producir hormonas"], "correct": "B", "explanation": "Los eritrocitos transportan O2 y CO2 mediante hemoglobina."}, {"id": 73, "sec": "sec-cta", "secTitle": "CTA - Biologia", "cat": "Bioquimica", "text": "Molécula portadora de información genética:", "options": ["ARN", "ATP", "ADN", "Proteína", "Lípido"], "correct": "C", "explanation": "ADN almacena la información genética."}, {"id": 74, "sec": "sec-cta", "secTitle": "CTA - Ecologia", "cat": "Efecto invernadero", "text": "Principal gas de efecto invernadero antropogénico:", "options": ["O2", "N2", "CO2", "H2", "Ne"], "correct": "C", "explanation": "CO2 es el principal gas de efecto invernadero de origen humano."}, {"id": 75, "sec": "sec-cta", "secTitle": "CTA - Quimica", "cat": "Soluciones", "text": "Solución de 20 g de sal en 80 g de agua. Concentración %m/m:", "options": ["10%", "15%", "20%", "25%", "30%"], "correct": "C", "explanation": "%m/m = soluto/(soluto+solvente) = 20/100 = 20%."}, {"id": 76, "sec": "sec-humanidades", "secTitle": "Humanidades - Lenguaje", "cat": "Sinonimos", "text": "Sinónimo de EFÍMERO:", "options": ["Eterno", "Breve", "Lento", "Grande", "Oscuro"], "correct": "B", "explanation": "Efímero = breve, pasajero."}, {"id": 77, "sec": "sec-humanidades", "secTitle": "Humanidades - Lenguaje", "cat": "Antonimos", "text": "Antónimo de ANTIGUO:", "options": ["Viejo", "Anticuado", "Moderno", "Primitivo", "Remoto"], "correct": "C", "explanation": "Antónimo de antiguo es moderno o reciente."}, {"id": 78, "sec": "sec-humanidades", "secTitle": "Humanidades - Lenguaje", "cat": "Tildacion", "text": "¿Cuál frase está correctamente tildada?", "options": ["El café esta caliente.", "El café está caliente.", "El cafe está caliente.", "El café está caliénte.", "El café està caliente."], "correct": "B", "explanation": "'está' lleva tilde por ser forma del verbo 'estar'."}, {"id": 79, "sec": "sec-humanidades", "secTitle": "Humanidades - Literatura", "cat": "Literatura universal", "text": "Autor de 'Cien años de soledad':", "options": ["Mario Vargas Llosa", "Gabriel García Márquez", "Julio Cortázar", "Pablo Neruda", "Jorge Icaza"], "correct": "B", "explanation": "Gabo es el autor de Cien años de soledad (1967)."}, {"id": 80, "sec": "sec-humanidades", "secTitle": "Humanidades - Literatura", "cat": "Literatura peruana", "text": "Obra de César Vallejo dedicada a su madre:", "options": ["Los heraldos negros", "Trilce", "Poemas humanos", "España, aparta de mí este cáliz", "La piedra cansada"], "correct": "C", "explanation": "'Poemas humanos' contiene 'Madre, me voy mañana...'."}, {"id": 81, "sec": "sec-humanidades", "secTitle": "Humanidades - Historia del Peru", "cat": "Republica", "text": "Presidente del Perú durante la Guerra del Pacífico (1879-1884):", "options": ["Ramón Castilla", "Miguel de San Román", "Andrés A. Cáceres", "Piérola", "Billinghurst"], "correct": "C", "explanation": "Cáceres organizó la resistencia en la Sierra durante la guerra."}, {"id": 82, "sec": "sec-humanidades", "secTitle": "Humanidades - Historia del Peru", "cat": "Independencia", "text": "Año de la independencia del Perú:", "options": ["1810", "1821", "1824", "1830", "1845"], "correct": "B", "explanation": "La independencia fue proclamada por San Martín en 1821."}, {"id": 83, "sec": "sec-humanidades", "secTitle": "Humanidades - Historia Universal", "cat": "Edad Moderna", "text": "Año de la Revolución Francesa:", "options": ["1688", "1789", "1815", "1848", "1914"], "correct": "B", "explanation": "La Revolución Francesa estalló en 1789."}, {"id": 84, "sec": "sec-humanidades", "secTitle": "Humanidades - Geografia", "cat": "Geografia del Peru", "text": "Cordillera que recorre el Perú de sur a norte:", "options": ["Andes", "Himalaya", "Alpes", "Pirineos", "Rockies"], "correct": "A", "explanation": "Los Andes recorren el Perú de SE a NO."}, {"id": 85, "sec": "sec-humanidades", "secTitle": "Humanidades - Geografia", "cat": "Clima", "text": "Corriente fría que afecta la costa peruana:", "options": ["Gulf Stream", "Brasil", "Humboldt", "Kuroshio", "El Niño"], "correct": "C", "explanation": "La corriente de Humboldt enfría la costa."}, {"id": 86, "sec": "sec-humanidades", "secTitle": "Humanidades - Economia", "cat": "Oferta y demanda", "text": "Si la oferta sube y la demanda baja, el precio tiende a:", "options": ["Subir", "Bajar", "Quedarse igual", "Subir y luego bajar", "Indefinible"], "correct": "B", "explanation": "Más oferta y menos demanda presionan el precio a la baja."}, {"id": 87, "sec": "sec-humanidades", "secTitle": "Humanidades - Economia", "cat": "PBI", "text": "El PBI mide:", "options": ["El valor total de bienes y servicios producidos en un país en un período.", "Solo el consumo de los hogares.", "Las exportaciones del país.", "El dinero en circulación.", "El gasto público."], "correct": "A", "explanation": "PBI = valor monetario de la producción final de un país en un periodo."}, {"id": 88, "sec": "sec-humanidades", "secTitle": "Humanidades - Civica", "cat": "Constitucion", "text": "Artículo de la Constitución peruana que consagra el derecho a la educación:", "options": ["Art. 1", "Art. 13", "Art. 21", "Art. 28", "Art. 44"], "correct": "B", "explanation": "El derecho a la educación está regulado en el Art. 13 de la CP."}, {"id": 89, "sec": "sec-humanidades", "secTitle": "Humanidades - Civica", "cat": "Democracia", "text": "Edad de sufragio en el Perú:", "options": ["16", "17", "18", "21", "25"], "correct": "C", "explanation": "En el Perú se vota desde los 18 años."}, {"id": 90, "sec": "sec-humanidades", "secTitle": "Humanidades - Filosofia", "cat": "Corrientes", "text": "Filósofo que dijo 'Pienso, luego existo':", "options": ["Platón", "Aristóteles", "Descartes", "Kant", "Hume"], "correct": "C", "explanation": "'Cogito, ergo sum' es la famosa sentencia cartesiana."}, {"id": 91, "sec": "sec-humanidades", "secTitle": "Humanidades - Filosofia", "cat": "Logica", "text": "Falacia que ataca a la persona en lugar del argumento:", "options": ["Ad verecundiam", "Ad hominem", "Ad baculum", "Petitio principii", "Non sequitur"], "correct": "B", "explanation": "Ad hominem = atacar al argumentador en lugar del argumento."}, {"id": 92, "sec": "sec-humanidades", "secTitle": "Humanidades - Psicologia", "cat": "Procesos cognitivos", "text": "Capacidad de mantener la información por segundos:", "options": ["Memoria a corto plazo", "Memoria a largo plazo", "Memoria sensorial", "Memoria procedimental", "Memoria declarativa"], "correct": "A", "explanation": "MCP retiene info brevemente (~15-30 s)."}, {"id": 93, "sec": "sec-humanidades", "secTitle": "Humanidades - Psicologia", "cat": "Conducta", "text": "Refuerzo positivo según Skinner:", "options": ["Castigo", "Estímulo agradable tras conducta", "Estímulo desagradable", "Extinción", "Saciedad"], "correct": "B", "explanation": "Refuerzo positivo = añadir estímulo agradable para aumentar la conducta."}, {"id": 94, "sec": "sec-humanidades", "secTitle": "Humanidades - Educacion civica", "cat": "Principios", "text": "Principio constitucional de igualdad ante la ley:", "options": ["Legalidad", "Igualdad", "Solidaridad", "Autonomía", "Tributación"], "correct": "B", "explanation": "El principio de igualdad está en el Art. 2 inc. 2."}, {"id": 95, "sec": "sec-humanidades", "secTitle": "Humanidades - Arte", "cat": "Pintura", "text": "Pintor de 'La última cena':", "options": ["Miguel Ángel", "Rafael", "Leonardo da Vinci", "Donatello", "Caravaggio"], "correct": "C", "explanation": "La Última Cena es obra de Leonardo da Vinci."}, {"id": 96, "sec": "sec-humanidades", "secTitle": "Humanidades - Musica", "cat": "Compositores", "text": "Compositor de 'La flauta mágica':", "options": ["Bach", "Mozart", "Beethoven", "Chopin", "Tchaikovsky"], "correct": "B", "explanation": "Mozart compuso La flauta mágica."}, {"id": 97, "sec": "sec-humanidades", "secTitle": "Humanidades - Religiones", "cat": "Historia", "text": "Reforma Protestante (luteranismo) año de inicio:", "options": ["1453", "1517", "1534", "1618", "1648"], "correct": "B", "explanation": "Lutero publica las 95 tesis en 1517."}, {"id": 98, "sec": "sec-humanidades", "secTitle": "Humanidades - Religion", "cat": "Texto sagrado", "text": "Libro sagrado del Islam:", "options": ["Biblia", "Torá", "Corán", "Vedas", "Sutta"], "correct": "C", "explanation": "El Corán es el libro sagrado del Islam."}, {"id": 99, "sec": "sec-humanidades", "secTitle": "Humanidades - Tecnologia", "cat": "Informatica", "text": "Memoria volátil de la computadora:", "options": ["ROM", "RAM", "HDD", "SSD", "DVD"], "correct": "B", "explanation": "RAM es memoria volátil; pierde los datos al apagar."}, {"id": 100, "sec": "sec-humanidades", "secTitle": "Humanidades - Ecologia", "cat": "Cambio climatico", "text": "Gas principal del efecto invernadero natural:", "options": ["CH4", "CO2", "N2O", "O3", "Vapor de agua"], "correct": "E", "explanation": "El vapor de agua es el GEI natural más importante."}]